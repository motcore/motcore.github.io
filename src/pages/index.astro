---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="14" cy="14" r="4" fill="#00d4ff"/>
          <circle cx="14" cy="14" r="6.5" stroke="#00d4ff" stroke-width="1.5" fill="none"/>
          <line x1="14" y1="0" x2="14" y2="7.5" stroke="#00d4ff" stroke-width="2" stroke-linecap="round"/>
          <line x1="14" y1="20.5" x2="14" y2="28" stroke="#00d4ff" stroke-width="2" stroke-linecap="round"/>
          <line x1="0" y1="14" x2="7.5" y2="14" stroke="#00d4ff" stroke-width="2" stroke-linecap="round"/>
          <line x1="20.5" y1="14" x2="28" y2="14" stroke="#00d4ff" stroke-width="2" stroke-linecap="round"/>
          <circle cx="14" cy="2"  r="2" fill="#00d4ff"/>
          <circle cx="14" cy="26" r="2" fill="#00d4ff"/>
          <circle cx="2"  cy="14" r="2" fill="#00d4ff"/>
          <circle cx="26" cy="14" r="2" fill="#00d4ff"/>
        </svg>
        <span>Motcore</span>
      </a>
      <div class="nav-links">
        <a href="#concept">Concept</a>
        <a href="#scale">Scale</a>
        <a href="#build">Build</a>
        <a href="https://github.com/Motcore/poc" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
      </div>
    </div>
  </nav>

  <main>

    <!-- HERO -->
    <section class="hero">
      <div class="section-inner hero-inner">
        <div class="badge">Open Hardware · v0.1 Proof of Concept</div>

        <h1>
          One motor.<br />
          <span class="accent">Every axis.</span>
        </h1>

        <p class="tagline">
          Motcore is a modular open hardware actuator that multiplexes motion
          across unlimited independent axes from a single motor —
          enabling robots that are simpler, cheaper, and more energy-efficient.
        </p>

        <div class="cta-group">
          <a href="https://github.com/Motcore/poc" class="btn btn-primary" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            View on GitHub
          </a>
          <a href="#concept" class="btn btn-ghost">Explore the concept →</a>
        </div>

        <div class="stats">
          <div class="stat">
            <span class="stat-value">1</span>
            <span class="stat-label">Motor</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">4+</span>
            <span class="stat-label">Axes per cube</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">~€50</span>
            <span class="stat-label">BOM v0.1</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">100%</span>
            <span class="stat-label">Open source</span>
          </div>
        </div>
      </div>
    </section>

    <!-- CONCEPT -->
    <section class="section" id="concept">
      <div class="section-inner">
        <div class="section-label">The Concept</div>
        <h2>Two parts. <span class="accent">Infinite configurations.</span></h2>
        <p class="section-desc">
          Motcore separates motion generation from motion distribution.
          The motor provides the energy; the cube decides where it goes.
        </p>

        <div class="two-col">
          <div class="concept-card">
            <div class="concept-icon">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <rect x="8" y="14" width="18" height="12" rx="2" stroke="#00d4ff" stroke-width="1.5" fill="none"/>
                <line x1="26" y1="20" x2="34" y2="20" stroke="#00d4ff" stroke-width="2" stroke-linecap="round"/>
                <circle cx="30" cy="20" r="3" fill="#00d4ff"/>
                <line x1="4" y1="16" x2="8" y2="16" stroke="#00d4ff" stroke-width="1.5"/>
                <line x1="4" y1="20" x2="8" y2="20" stroke="#00d4ff" stroke-width="1.5"/>
                <line x1="4" y1="24" x2="8" y2="24" stroke="#00d4ff" stroke-width="1.5"/>
              </svg>
            </div>
            <h3>The Motor</h3>
            <p>Any continuously rotating motor. Swap it freely — more torque, more speed, different size. The cube doesn't care. One cheap motor powers the whole system.</p>
          </div>

          <div class="concept-card highlight">
            <div class="concept-icon">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <circle cx="20" cy="20" r="5" fill="#00d4ff"/>
                <circle cx="20" cy="20" r="8" stroke="#00d4ff" stroke-width="1.5" fill="none"/>
                <line x1="20" y1="4"  x2="20" y2="11.5" stroke="#00d4ff" stroke-width="2" stroke-linecap="round"/>
                <line x1="20" y1="28.5" x2="20" y2="36" stroke="#00d4ff" stroke-width="2" stroke-linecap="round"/>
                <line x1="4"  y1="20" x2="11.5" y2="20" stroke="#00d4ff" stroke-width="2" stroke-linecap="round"/>
                <line x1="28.5" y1="20" x2="36" y2="20" stroke="#00d4ff" stroke-width="2" stroke-linecap="round"/>
                <circle cx="20" cy="5"  r="2.5" fill="#00d4ff"/>
                <circle cx="20" cy="35" r="2.5" fill="#00d4ff"/>
                <circle cx="5"  cy="20" r="2.5" fill="#00d4ff"/>
                <circle cx="35" cy="20" r="2.5" fill="#00d4ff"/>
              </svg>
            </div>
            <h3>The Cube <span class="tag">Core innovation</span></h3>
            <p>The motion multiplexer. Four output axes, each independently controlled through selective friction engagement. No gearboxes, no clutches — just physics. And it's the foundation you build everything else on.</p>
          </div>
        </div>

        <div class="principle-row">
          <div class="principle">
            <div class="principle-title">Friction as a feature</div>
            <p>Servo-controlled friction wheels selectively engage each output axis. Direction, speed, engagement — all independent from a single rotating input.</p>
          </div>
          <div class="principle">
            <div class="principle-title">Physics does the work</div>
            <p>Inspired by passive dynamics and compliant mechanisms. The geometry and materials handle the "thinking", minimizing software complexity.</p>
          </div>
          <div class="principle">
            <div class="principle-title">Better Cost of Transport</div>
            <p>Fewer motors means less weight, less wiring, less control overhead. Robots built on Motcore move more naturally and use energy more efficiently.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SCALE -->
    <section class="section section-dark" id="scale">
      <div class="section-inner">
        <div class="section-label">Scalability</div>
        <h2>Chain cubes. <span class="accent">Multiply motion.</span></h2>
        <p class="section-desc">
          Connect cubes together and the outputs grow exponentially.
          One motor can reach every joint of a complex robot.
        </p>

        <div class="chain-table">
          <div class="chain-header">
            <span>Configuration</span>
            <span>Direct</span>
            <span>Indirect</span>
            <span>Total</span>
          </div>
          <div class="chain-row">
            <span class="chain-config">
              <span class="cube primary">M</span>
              <span class="chain-plus">+</span>
              <span class="cube">C</span>
              <span class="chain-label">1 cube</span>
            </span>
            <span class="chain-val direct">4</span>
            <span class="chain-val indirect">0</span>
            <span class="chain-val total">4</span>
          </div>
          <div class="chain-row">
            <span class="chain-config">
              <span class="cube primary">M</span>
              <span class="chain-plus">+</span>
              <span class="cube">C</span>
              <span class="chain-plus">+</span>
              <span class="cube secondary">C</span>
              <span class="chain-label">2 cubes</span>
            </span>
            <span class="chain-val direct">3</span>
            <span class="chain-val indirect">4</span>
            <span class="chain-val total">7</span>
          </div>
          <div class="chain-row">
            <span class="chain-config">
              <span class="cube primary">M</span>
              <span class="chain-plus">+</span>
              <span class="cube">C</span>
              <span class="chain-plus">+</span>
              <span class="cube secondary">C</span>
              <span class="cube secondary">C</span>
              <span class="cube secondary">C</span>
              <span class="chain-label">4 cubes</span>
            </span>
            <span class="chain-val direct">1</span>
            <span class="chain-val indirect">12</span>
            <span class="chain-val total">13</span>
          </div>
          <div class="chain-row highlight-row">
            <span class="chain-config">
              <span class="cube primary">M</span>
              <span class="chain-plus">+</span>
              <span class="cube">C</span>
              <span class="chain-plus">+</span>
              <span class="cube secondary">C</span>
              <span class="cube secondary">C</span>
              <span class="cube secondary">C</span>
              <span class="cube secondary">C</span>
              <span class="chain-label">5 cubes</span>
            </span>
            <span class="chain-val direct">0</span>
            <span class="chain-val indirect">16</span>
            <span class="chain-val total accent-val">16</span>
          </div>
        </div>

        <p class="chain-note">
          <strong>M</strong> = Motor &nbsp;·&nbsp; <strong>C</strong> = Motcore Cube &nbsp;·&nbsp;
          <span style="color:var(--cyan)">■</span> Direct &nbsp;·&nbsp;
          <span style="color:var(--cyan-dim)">■</span> Indirect (chained)
        </p>

        <div class="callout">
          <span class="callout-icon">💡</span>
          <p>16 independently controlled axes. One motor. Imagine a quadruped robot with 4 legs × 4 joints each — fully actuated, from a single €3 motor.</p>
        </div>
      </div>
    </section>

    <!-- BUILD -->
    <section class="section" id="build">
      <div class="section-inner">
        <div class="section-label">For Makers</div>
        <h2>Start from the cube. <span class="accent">Build anything.</span></h2>
        <p class="section-desc">
          You don't start from zero. The cube is your foundation —
          mechanics, firmware, and community models, ready to go.
        </p>

        <div class="three-col">
          <div class="feature-card">
            <div class="feature-icon">⚙️</div>
            <h3>Parametric CAD</h3>
            <p>FreeCAD models fully parametric. Change motor size, axis count, or friction material — the design updates automatically.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">💻</div>
            <h3>Firmware included</h3>
            <p>Arduino-based control system, ready to flash. Multi-axis control, touchscreen interface, serial protocol. Build on top, don't start from scratch.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">🤝</div>
            <h3>Share models</h3>
            <p>Built a quadruped on Motcore? Share the 3D design and firmware. Someone else can reproduce it in hours, not months.</p>
          </div>
        </div>

        <div class="cta-centered">
          <a href="https://github.com/Motcore/poc" class="btn btn-primary" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            Explore the repo
          </a>
          <a href="https://github.com/Motcore/poc/blob/main/CONTRIBUTING.md" class="btn btn-ghost" target="_blank" rel="noopener">
            Contribute →
          </a>
        </div>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer>
    <div class="footer-inner">
      <span>© 2025 Javier Asensio Montiel</span>
      <span class="footer-sep">·</span>
      <a href="https://github.com/Motcore/poc/blob/main/LICENSE-HARDWARE.md" target="_blank" rel="noopener">CERN-OHL-P-2.0</a>
      <span class="footer-sep">·</span>
      <a href="https://github.com/Motcore" target="_blank" rel="noopener">GitHub</a>
    </div>
  </footer>
</Layout>

<style>
  /* ─── NAV ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    border-bottom: 1px solid var(--navy-border);
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(12px);
  }
  .nav-inner {
    max-width: 1024px;
    margin: 0 auto;
    padding: 0 24px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--white);
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .nav-links a {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--grey);
    font-size: 0.9rem;
    transition: color 0.2s;
    text-decoration: none;
  }
  .nav-links a:hover { color: var(--white); text-decoration: none; }

  /* ─── SECTIONS ─── */
  .section { padding: 100px 24px; }
  .section-dark {
    background: var(--navy-mid);
    border-top: 1px solid var(--navy-border);
    border-bottom: 1px solid var(--navy-border);
  }
  .section-inner {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 32px;
  }
  .section-label {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--cyan);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }
  h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
  }
  .section-desc {
    font-size: 1.05rem;
    color: var(--grey);
    line-height: 1.7;
    max-width: 560px;
  }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 100px 24px 80px;
  }
  .hero-inner { gap: 28px; }
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 14px;
    border-radius: 999px;
    background: rgba(0, 212, 255, 0.08);
    border: 1px solid rgba(0, 212, 255, 0.25);
    color: var(--cyan);
    font-size: 0.78rem;
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }
  h1 {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
  }
  .accent { color: var(--cyan); }
  .tagline {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--grey);
    max-width: 580px;
  }
  .cta-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-primary { background: var(--cyan); color: var(--navy); }
  .btn-primary:hover { background: #33deff; text-decoration: none; transform: translateY(-1px); }
  .btn-ghost { background: transparent; color: var(--white); border: 1px solid var(--navy-border); }
  .btn-ghost:hover { border-color: var(--grey); text-decoration: none; transform: translateY(-1px); }

  .stats {
    display: flex;
    align-items: center;
    border: 1px solid var(--navy-border);
    border-radius: 12px;
    overflow: hidden;
    width: 100%;
    max-width: 560px;
  }
  .stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20px 12px;
    background: var(--navy-mid);
    gap: 4px;
  }
  .stat-value { font-size: 1.5rem; font-weight: 800; color: var(--cyan); letter-spacing: -0.02em; }
  .stat-label { font-size: 0.72rem; color: var(--grey); text-transform: uppercase; letter-spacing: 0.08em; }
  .stat-divider { width: 1px; align-self: stretch; background: var(--navy-border); }

  /* ─── CONCEPT ─── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    width: 100%;
    text-align: left;
  }
  .concept-card {
    padding: 28px;
    border: 1px solid var(--navy-border);
    border-radius: 12px;
    background: var(--navy-mid);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .concept-card.highlight {
    border-color: rgba(0,212,255,0.3);
    background: rgba(0,212,255,0.04);
  }
  .concept-icon { display: flex; }
  .concept-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .tag {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    font-weight: 400;
    color: var(--cyan);
    background: rgba(0,212,255,0.1);
    border: 1px solid rgba(0,212,255,0.2);
    padding: 2px 8px;
    border-radius: 999px;
  }
  .concept-card p { font-size: 0.9rem; color: var(--grey); line-height: 1.65; }

  .principle-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    width: 100%;
    text-align: left;
  }
  .principle {
    padding: 20px;
    border: 1px solid var(--navy-border);
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .principle-title { font-weight: 600; font-size: 0.9rem; color: var(--white); }
  .principle p { font-size: 0.85rem; color: var(--grey); line-height: 1.6; }

  /* ─── CHAIN TABLE ─── */
  .chain-table {
    width: 100%;
    border: 1px solid var(--navy-border);
    border-radius: 12px;
    overflow: hidden;
    font-size: 0.9rem;
  }
  .chain-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    padding: 12px 20px;
    background: var(--navy);
    border-bottom: 1px solid var(--navy-border);
    color: var(--grey);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: left;
  }
  .chain-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    padding: 14px 20px;
    border-bottom: 1px solid var(--navy-border);
    align-items: center;
    text-align: left;
    background: var(--navy-mid);
    transition: background 0.15s;
  }
  .chain-row:last-child { border-bottom: none; }
  .chain-row:hover { background: rgba(0,212,255,0.03); }
  .highlight-row { background: rgba(0,212,255,0.05) !important; }
  .chain-config {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
