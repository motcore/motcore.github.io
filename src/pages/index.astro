---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <!-- Central gear -->
          <circle cx="14" cy="14" r="4" fill="#00d4ff"/>
          <circle cx="14" cy="14" r="6.5" stroke="#00d4ff" stroke-width="1.5" fill="none"/>
          <!-- Axes -->
          <line x1="14" y1="0" x2="14" y2="7.5" stroke="#00d4ff" stroke-width="2" stroke-linecap="round"/>
          <line x1="14" y1="20.5" x2="14" y2="28" stroke="#00d4ff" stroke-width="2" stroke-linecap="round"/>
          <line x1="0" y1="14" x2="7.5" y2="14" stroke="#00d4ff" stroke-width="2" stroke-linecap="round"/>
          <line x1="20.5" y1="14" x2="28" y2="14" stroke="#00d4ff" stroke-width="2" stroke-linecap="round"/>
          <!-- Axis caps -->
          <circle cx="14" cy="2"  r="2" fill="#00d4ff"/>
          <circle cx="14" cy="26" r="2" fill="#00d4ff"/>
          <circle cx="2"  cy="14" r="2" fill="#00d4ff"/>
          <circle cx="26" cy="14" r="2" fill="#00d4ff"/>
        </svg>
        <span>Motcore</span>
      </a>
      <div class="nav-links">
        <a href="https://github.com/Motcore/poc" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <main>
    <section class="hero">
      <div class="hero-inner">

        <div class="badge">v0.1 · Proof of Concept</div>

        <h1>
          One motor.<br />
          <span class="accent">Multiple independent axes.</span>
        </h1>

        <p class="tagline">
          Motcore is an open hardware actuator that controls multiple axes
          from a single motor using selective friction engagement —
          no gearboxes, no clutches, just physics.
        </p>

        <div class="cta-group">
          <a href="https://github.com/Motcore/poc" class="btn btn-primary" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            View on GitHub
          </a>
          <a href="https://github.com/Motcore/poc/blob/main/docs/assembly.md" class="btn btn-ghost" target="_blank" rel="noopener">
            Read the docs →
          </a>
        </div>

        <!-- DIAGRAM -->
        <div class="diagram">
          <div class="diagram-inner">
            <div class="axis axis-top">
              <div class="axis-line"></div>
              <div class="axis-cap"></div>
            </div>
            <div class="axis axis-bottom">
              <div class="axis-cap"></div>
              <div class="axis-line"></div>
            </div>
            <div class="axis axis-left">
              <div class="axis-cap"></div>
              <div class="axis-line"></div>
            </div>
            <div class="axis axis-right">
              <div class="axis-line"></div>
              <div class="axis-cap"></div>
            </div>
            <div class="hub">
              <div class="hub-ring"></div>
              <div class="hub-core"></div>
            </div>
          </div>
          <p class="diagram-caption">Single motor → 4 independently controlled axes</p>
        </div>

        <!-- STATS -->
        <div class="stats">
          <div class="stat">
            <span class="stat-value">1</span>
            <span class="stat-label">Motor</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">4+</span>
            <span class="stat-label">Axes</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">~€50</span>
            <span class="stat-label">BOM cost</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">100%</span>
            <span class="stat-label">Open source</span>
          </div>
        </div>

      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer>
    <div class="footer-inner">
      <span>© 2025 Javier Asensio Montiel</span>
      <span class="footer-sep">·</span>
      <a href="https://github.com/Motcore/poc/blob/main/LICENSE-HARDWARE.md" target="_blank" rel="noopener">CERN-OHL-P-2.0</a>
      <span class="footer-sep">·</span>
      <a href="https://github.com/Motcore" target="_blank" rel="noopener">GitHub</a>
    </div>
  </footer>
</Layout>

<style>
  /* NAV */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    border-bottom: 1px solid var(--navy-border);
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(12px);
  }

  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--white);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    gap: 20px;
  }

  .nav-links a {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--grey);
    font-size: 0.9rem;
    transition: color 0.2s;
    text-decoration: none;
  }

  .nav-links a:hover {
    color: var(--white);
    text-decoration: none;
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 100px 24px 60px;
  }

  .hero-inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 32px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 14px;
    border-radius: 999px;
    background: rgba(0, 212, 255, 0.08);
    border: 1px solid rgba(0, 212, 255, 0.25);
    color: var(--cyan);
    font-size: 0.8rem;
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }

  h1 {
    font-size: clamp(2.8rem, 7vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--white);
  }

  .accent {
    color: var(--cyan);
  }

  .tagline {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--grey);
    max-width: 560px;
  }

  /* CTA */
  .cta-group {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--cyan);
    color: var(--navy);
  }

  .btn-primary:hover {
    background: #33deff;
    text-decoration: none;
    transform: translateY(-1px);
  }

  .btn-ghost {
    background: transparent;
    color: var(--white);
    border: 1px solid var(--navy-border);
  }

  .btn-ghost:hover {
    border-color: var(--grey);
    text-decoration: none;
    transform: translateY(-1px);
  }

  /* DIAGRAM */
  .diagram {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 40px;
    border: 1px solid var(--navy-border);
    border-radius: 16px;
    background: var(--navy-mid);
    width: 100%;
    max-width: 440px;
  }

  .diagram-inner {
    position: relative;
    width: 160px;
    height: 160px;
  }

  .hub {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
  }

  .hub-ring {
    position: absolute;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 2px solid var(--cyan);
  }

  .hub-core {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--cyan);
  }

  .axis {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .axis-line {
    background: var(--cyan);
    opacity: 0.7;
  }

  .axis-cap {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--cyan);
    flex-shrink: 0;
  }

  .axis-top, .axis-bottom {
    flex-direction: column;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
  }

  .axis-top {
    top: 0;
    height: 44px;
  }

  .axis-top .axis-line {
    width: 3px;
    flex: 1;
  }

  .axis-bottom {
    bottom: 0;
    height: 44px;
  }

  .axis-bottom .axis-line {
    width: 3px;
    flex: 1;
  }

  .axis-left, .axis-right {
    flex-direction: row;
    top: 50%;
    transform: translateY(-50%);
    height: 12px;
  }

  .axis-left {
    left: 0;
    width: 44px;
  }

  .axis-left .axis-line {
    height: 3px;
    flex: 1;
  }

  .axis-right {
    right: 0;
    width: 44px;
  }

  .axis-right .axis-line {
    height: 3px;
    flex: 1;
  }

  .diagram-caption {
    font-size: 0.8rem;
    color: var(--grey);
    font-family: var(--font-mono);
  }

  /* STATS */
  .stats {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid var(--navy-border);
    border-radius: 12px;
    overflow: hidden;
    width: 100%;
    max-width: 520px;
  }

  .stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20px 16px;
    background: var(--navy-mid);
    gap: 4px;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--cyan);
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--grey);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .stat-divider {
    width: 1px;
    align-self: stretch;
    background: var(--navy-border);
  }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--navy-border);
    padding: 24px;
  }

  .footer-inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    font-size: 0.85rem;
    color: var(--grey);
  }

  .footer-sep {
    opacity: 0.4;
  }

  /* RESPONSIVE */
  @media (max-width: 480px) {
    .stats {
      flex-wrap: wrap;
    }
    .stat-divider {
      display: none;
    }
    .stat {
      min-width: 50%;
    }
  }
</style>
